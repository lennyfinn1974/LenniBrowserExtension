{
  "manifest_version": 3,
  "name": "Lenni — AI Execution Agent",
  "version": "1.1.0",
  "description": "Your local AI assistant in every browser tab. Chat, analyse pages, control your browser.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "sidePanel",
    "storage",
    "notifications",
    "debugger"
  ],
  "host_permissions": [
    "http://localhost:8200/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["styles/overlay.css"],
    "run_at": "document_idle"
  }],
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
